generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  password  String    
  tmdbToken String?   
  reviews   Review[]
  favorites Favorite[]
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  content   String
  movieId   Int      // TMDB Movie ID
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Favorite {
  id        String   @id @default(uuid())
  movieId   Int      // TMDB Movie ID
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}